# 문의 폼 제출 시 이메일로 알림을 받으려면:
# 1. https://formspree.io 가입 후 새 폼 생성
# 2. 생성된 폼의 "Endpoint" URL 복사 (예: https://formspree.io/f/xxxxxxxx)
# 3. 아래 변수로 프로젝트 루트에 .env.local 파일 생성 후 붙여넣기

FORMSPREE_ENDPOINT=https://formspree.io/f/여기에_본인_폼_ID_입력

# ===== 사이트 URL (SEO, OG, canonical, sitemap 등) =====
# 로컬: 필요 시 .env.local에 설정 (예: http://localhost:3000)
# Netlify 프로덕션: netlify.toml의 [context.production.environment]에서 SITE_URL 설정 권장 (또는 Netlify 대시보드에서)
# Netlify 프리뷰: 설정하지 않으면 자동으로 DEPLOY_PRIME_URL(프리뷰 주소)이 사용됨

# SITE_URL=https://bellocompany.co.kr
